# Copy this file to .env and fill in the values

NODE_ENV=development
PORT=3000

# MongoDB connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?appName=<AppName>

# TENGRAPH WFS query endpoint (WA SLIP public service)
TENGRAPH_API_URL=https://services.slip.wa.gov.au/public/rest/services/SLIP_Public_Services/Industry_and_Mining_WFS/MapServer/3/query

# Production only: comma-separated list of allowed CORS origins
# Leave empty in development
ALLOWED_ORIGINS=

# Commodity Price API key (commoditypriceapi.com)
COMMODITY_API_KEY=your_api_key_here
